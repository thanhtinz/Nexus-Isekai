<%- include('../layout_head', {pageTitle:'Tin tức'}) %>
<div style="max-width:1200px;margin:0 auto;padding:48px 24px">
  <div class="section-title">
    <h2>📰 Tin Tức & Thông Báo</h2>
  </div>
  <!-- Category filter -->
  <div style="display:flex;gap:8px;justify-content:center;flex-wrap:wrap;margin-bottom:32px">
    <% ['','general','update','event','maintenance','notice'].forEach(c=>{ %>
    <a href="/news<%= c?'?category='+c:'' %>" class="sv-btn <%= category===c?'active':'' %>">
      <%= {'':"Tất cả",'general':'Chung','update':'Cập nhật','event':'Sự kiện','maintenance':'Bảo trì','notice':'Thông báo'}[c] %>
    </a>
    <% }) %>
  </div>
  <div class="news-grid">
    <% articles.forEach(a=>{ %>
    <a href="/news/<%= a.slug %>" class="news-card">
      <div class="news-thumb">
        <% if(a.thumbnail){ %><img src="<%= a.thumbnail %>" alt="">
        <% } else { %><% const icons={'event':'⚡','update':'🔧','maintenance':'🛠️','notice':'📢'}; %><%= icons[a.category]||'📰' %><% } %>
      </div>
      <div class="news-body">
        <% if(a.is_pinned){ %><span style="font-size:.7rem;color:var(--gold)">📌 Ghim </span><% } %>
        <span class="news-cat"><%= a.category %></span>
        <div class="news-title"><%= a.title %></div>
        <% if(a.excerpt){ %><div class="news-excerpt"><%= a.excerpt %></div><% } %>
        <div class="news-meta"><i class="fas fa-eye"></i> <%= a.views||0 %> • <%= a.published_at ? new Date(a.published_at).toLocaleDateString('vi-VN') : '' %></div>
      </div>
    </a>
    <% }) %>
    <% if(!articles.length){ %><div style="grid-column:1/-1;text-align:center;color:var(--muted);padding:48px">Không có bài viết nào</div><% } %>
  </div>
</div>
<%- include('../layout_foot') %>
