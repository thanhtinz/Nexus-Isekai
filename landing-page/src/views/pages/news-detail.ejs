<%- include('../layout_head', {pageTitle: article.title}) %>
<div style="max-width:860px;margin:0 auto;padding:48px 24px">
  <a href="/news" style="color:var(--muted);font-size:.85rem;display:inline-flex;align-items:center;gap:6px;margin-bottom:24px">
    <i class="fas fa-arrow-left"></i> Quay lại tin tức
  </a>
  <span class="news-cat"><%= article.category %></span>
  <h1 style="font-size:clamp(1.5rem,4vw,2.2rem);font-weight:800;margin:12px 0;line-height:1.3"><%= article.title %></h1>
  <div style="color:var(--muted);font-size:.83rem;margin-bottom:24px">
    <i class="fas fa-eye"></i> <%= article.views||0 %> lượt xem •
    <%= article.published_at ? new Date(article.published_at).toLocaleDateString('vi-VN',{day:'2-digit',month:'2-digit',year:'numeric'}) : '' %>
  </div>
  <% if(article.thumbnail){ %><img src="<%= article.thumbnail %>" style="width:100%;border-radius:12px;margin-bottom:28px"><% } %>
  <div style="line-height:1.8;font-size:.95rem;color:#d0d0e8"><%- article.content %></div>

  <% if(related.length){ %>
  <div style="margin-top:48px;border-top:1px solid var(--border);padding-top:32px">
    <h3 style="margin-bottom:20px;font-size:1rem">Tin liên quan</h3>
    <div class="news-grid" style="grid-template-columns:repeat(auto-fill,minmax(240px,1fr))">
      <% related.filter(r=>r.slug!==article.slug).slice(0,3).forEach(a=>{ %>
      <a href="/news/<%= a.slug %>" class="news-card">
        <div class="news-thumb" style="height:120px"><%= {'event':'⚡','update':'🔧','maintenance':'🛠️','notice':'📢'}[a.category]||'📰' %></div>
        <div class="news-body"><span class="news-cat"><%= a.category %></span><div class="news-title"><%= a.title %></div></div>
      </a>
      <% }) %>
    </div>
  </div>
  <% } %>
</div>
<%- include('../layout_foot') %>
