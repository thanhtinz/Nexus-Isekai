# Nexus Isekai — Server Configuration
# Copy file này thành application.properties và điền thông tin thực
# KHÔNG commit application.properties lên git!

# ─── Database ─────────────────────────────────────────────────
db.url=jdbc:mysql://localhost:3306/nexus_isekai?useSSL=false&serverTimezone=Asia/Ho_Chi_Minh&allowPublicKeyRetrieval=true
db.username=nexus
db.password=CHANGE_THIS_PASSWORD
db.pool.size=20

# ─── Game Server ──────────────────────────────────────────────
game.port=7777
game.max.connections=5000
# ID duy nhất cho server này (quan trọng nếu chạy multi-server)
server.id=1
server.name=Server 1

# ─── Admin API ────────────────────────────────────────────────
# Chỉ bind localhost, KHÔNG expose ra internet
admin.port=8080
# Đổi thành chuỗi ngẫu nhiên dài (64+ ký tự)
admin.key=CHANGE_THIS_TO_LONG_RANDOM_STRING

# ─── Webshop HTTP ─────────────────────────────────────────────
webshop.port=9090
# URL public của webshop (dùng cho QR code SePay)
webshop.public.url=http://localhost:9090

# ─── SePay Payment Gateway ───────────────────────────────────
# Đăng ký tại https://sepay.vn
sepay.api.key=
sepay.webhook.secret=
sepay.bank.account=
sepay.bank.name=Vietcombank
sepay.account.name=

# ─── Voice Messages ───────────────────────────────────────────
voice.dir=voice-messages
voice.max.duration.ms=60000
voice.max.size.bytes=5242880

# ─── Events / Scheduler ───────────────────────────────────────
event.autosave.minutes=5
event.cross.relay.seconds=10
event.ping.seconds=30

# AI Content Generation (Claude API)
# Dang ky tai: https://console.anthropic.com/
anthropic.api.key=sk-ant-api03-YOUR_KEY_HERE
