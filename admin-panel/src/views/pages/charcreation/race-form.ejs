
<div class="card" style="max-width:620px">
  <div class="card-header">
    <h3><i class="fas fa-venus-mars"></i> <%= race?'Sửa':'Thêm' %> chủng tộc/giới tính</h3>
    <a href="/charcreation" class="btn btn-ghost btn-sm"><i class="fas fa-arrow-left"></i></a>
  </div>
  <form method="POST" action="/charcreation/race<%= race?'/'+race.id:'' %>">
    <div class="form-row">
      <div class="form-group"><label>Mã code *</label><input name="code" value="<%= race?.code||'' %>" placeholder="humn_male" required></div>
      <div class="form-group"><label>Giới tính *</label>
        <select name="gender"><option value="male" <%= race?.gender==='male'?'selected':'' %>>♂ Nam</option><option value="female" <%= race?.gender==='female'?'selected':'' %>>♀ Nữ</option></select>
      </div>
    </div>
    <div class="form-row">
      <div class="form-group"><label>Mã chủng tộc *</label><input name="race" value="<%= race?.race||'' %>" placeholder="humn / demn / gbln / elf" required></div>
      <div class="form-group"><label>Tên hiển thị (VN)</label><input name="race_name_vn" value="<%= race?.race_name_vn||'' %>" placeholder="Con Người"></div>
    </div>
    <div class="form-row">
      <div class="form-group"><label>Khóa theo phe (0 = mọi phe)</label><input name="faction_id" type="number" value="<%= race?.faction_id||0 %>" min="0" max="4"></div>
      <div class="form-group"><label>Thứ tự hiển thị</label><input name="sort_order" type="number" value="<%= race?.sort_order||0 %>"></div>
    </div>
    <div class="form-row">
      <div class="form-group"><label>Sprite body base (0bas)</label>
        <select name="base_asset_id"><option value="">— chọn asset —</option>
        <% bases.forEach(a=>{ %><option value="<%= a.id %>" <%= race?.base_asset_id===a.id?'selected':'' %>><%= a.name %></option><% }) %>
        </select>
      </div>
      <div class="form-group"><label>Ảnh preview (tùy chọn)</label>
        <select name="preview_asset_id"><option value="">— mặc định dùng base —</option>
        <% bases.forEach(a=>{ %><option value="<%= a.id %>" <%= race?.preview_asset_id===a.id?'selected':'' %>><%= a.name %></option><% }) %>
        </select>
      </div>
    </div>
    <div class="form-group"><label>Mô tả</label><textarea name="description" rows="2"><%= race?.description||'' %></textarea></div>
    <% if(race){ %><div class="form-group"><label style="display:flex;align-items:center;gap:8px;cursor:pointer"><input type="checkbox" name="is_enabled" value="1" <%= race.is_enabled?'checked':'' %>> Bật (hiển thị cho người chơi)</label></div><% } %>
    <button type="submit" class="btn btn-primary"><i class="fas fa-save"></i> Lưu</button>
  </form>
</div>
