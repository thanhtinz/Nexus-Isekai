<div style="display:flex;gap:12px;margin-bottom:20px"><a href="/business" class="btn btn-ghost btn-sm"><i class="fas fa-arrow-left"></i> Ngành nghề</a></div>
<div class="card" style="max-width:560px;margin-bottom:20px">
  <div class="card-header"><h3><i class="fas fa-plus"></i> Đặt cơ sở mới</h3></div>
  <form method="POST" action="/business/places">
    <div class="form-group"><label>Loại</label><select name="type_code">
      <% types.forEach(t=>{ %><option value="<%= t.type_code %>"><%= t.name_vn %></option><% }) %></select></div>
    <div class="form-group"><label>Tên cơ sở</label><input name="name" placeholder="Quán Trọ Rồng Vàng" required></div>
    <div class="form-row">
      <div class="form-group"><label>Zone</label><input name="zone_id" type="number" value="1"></div>
      <div class="form-group"><label>X</label><input name="pos_x" type="number" value="100"></div>
      <div class="form-group"><label>Y</label><input name="pos_y" type="number" value="100"></div>
    </div>
    <button type="submit" class="btn btn-primary">Đặt</button>
  </form>
</div>
<div class="card">
  <div class="card-header"><h3>Cơ sở đã đặt (<%= places.length %>)</h3></div>
  <table style="width:100%;border-collapse:collapse;font-size:.86rem">
    <thead><tr style="text-align:left;color:var(--muted)"><th style="padding:6px">Tên</th><th>Loại</th><th>Zone</th><th>Chủ</th><th>Quỹ</th></tr></thead>
    <tbody><% places.forEach(p=>{ %><tr style="border-bottom:1px solid var(--border)">
      <td style="padding:6px"><%= p.name %></td><td><%= p.type_name %></td><td><%= p.zone_id %></td>
      <td><%= p.owner_char_id||'Chưa thầu' %></td><td><%= Number(p.treasury).toLocaleString() %></td></tr><% }) %></tbody>
  </table>
</div>
