<div class="card" style="max-width:640px">
  <div class="card-header"><h3><i class="fas fa-store"></i> <%= type?'Sửa':'Thêm' %> ngành nghề</h3>
    <a href="/business" class="btn btn-ghost btn-sm"><i class="fas fa-arrow-left"></i></a></div>
  <form method="POST" action="/business<%= type?'/'+type.id:'' %>">
    <div class="form-row">
      <div class="form-group"><label>Mã code *</label><input name="type_code" value="<%= type?.type_code||'' %>" placeholder="tavern" required></div>
      <div class="form-group"><label>Danh mục</label><select name="category">
        <% Object.keys(CATEGORIES).forEach(k=>{ %><option value="<%= k %>" <%= type?.category===k?'selected':'' %>><%= CATEGORIES[k] %></option><% }) %>
      </select></div>
    </div>
    <div class="form-row">
      <div class="form-group"><label>Tên (EN) *</label><input name="name" value="<%= type?.name||'' %>" required></div>
      <div class="form-group"><label>Tên (VN)</label><input name="name_vn" value="<%= type?.name_vn||'' %>"></div>
    </div>
    <div class="form-group"><label>Mô tả</label><textarea name="description" rows="2"><%= type?.description||'' %></textarea></div>
    <div class="form-row">
      <div class="form-group"><label>Mã hành động làm việc</label><input name="job_action" value="<%= type?.job_action||'' %>" placeholder="cook / heal / patrol"></div>
      <div class="form-group"><label>Lương/lượt</label><input name="base_pay" type="number" value="<%= type?.base_pay??50 %>"></div>
    </div>
    <div class="form-row">
      <div class="form-group"><label>Giá thầu</label><input name="purchase_price" type="number" value="<%= type?.purchase_price??100000 %>"></div>
      <div class="form-group"><label>Thu nhập/ngày</label><input name="daily_income" type="number" value="<%= type?.daily_income??5000 %>"></div>
      <div class="form-group"><label>NV tối đa</label><input name="max_employees" type="number" value="<%= type?.max_employees??5 %>"></div>
    </div>
    <% if(type){ %><div class="form-group"><label style="display:flex;gap:8px;align-items:center"><input type="checkbox" name="is_enabled" value="1" <%= type.is_enabled?'checked':'' %>> Bật</label></div><% } %>
    <button type="submit" class="btn btn-primary"><i class="fas fa-save"></i> Lưu</button>
  </form>
</div>
