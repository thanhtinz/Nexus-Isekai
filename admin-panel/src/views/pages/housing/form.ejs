<div class="card" style="max-width:600px"><div class="card-header"><h3><i class="fas fa-house"></i> <%= type?'Sửa':'Thêm' %> loại nhà</h3>
<a href="/housing" class="btn btn-ghost btn-sm"><i class="fas fa-arrow-left"></i></a></div>
<form method="POST" action="/housing<%= type?'/'+type.id:'' %>">
<div class="form-row">
<div class="form-group"><label>Mã code *</label><input name="type_code" value="<%= type?.type_code||'' %>" placeholder="cottage" required></div>
<div class="form-group"><label>Hạng</label><select name="tier"><% Object.keys(TIERS).forEach(k=>{ %><option value="<%= k %>" <%= type?.tier===k?'selected':'' %>><%= TIERS[k] %></option><% }) %></select></div>
</div>
<div class="form-row">
<div class="form-group"><label>Tên (EN) *</label><input name="name" value="<%= type?.name||'' %>" required></div>
<div class="form-group"><label>Tên (VN)</label><input name="name_vn" value="<%= type?.name_vn||'' %>"></div>
</div>
<div class="form-group"><label>Mô tả</label><textarea name="description" rows="2"><%= type?.description||'' %></textarea></div>
<div class="form-row">
<div class="form-group"><label>Giá mua</label><input name="purchase_price" type="number" value="<%= type?.purchase_price??50000 %>"></div>
<div class="form-group"><label>Ô kho</label><input name="storage_slots" type="number" value="<%= type?.storage_slots??20 %>"></div>
<div class="form-group"><label>Nội thất tối đa</label><input name="max_furniture" type="number" value="<%= type?.max_furniture??30 %>"></div>
</div>
<% if(type){ %><div class="form-group"><label style="display:flex;gap:8px;align-items:center"><input type="checkbox" name="is_enabled" value="1" <%= type.is_enabled?'checked':'' %>> Bật</label></div><% } %>
<button type="submit" class="btn btn-primary"><i class="fas fa-save"></i> Lưu</button></form></div>
