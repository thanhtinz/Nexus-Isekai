<div style="margin-bottom:20px"><a href="/housing" class="btn btn-ghost btn-sm"><i class="fas fa-arrow-left"></i> Loại nhà</a></div>
<div class="card" style="max-width:560px;margin-bottom:20px"><div class="card-header"><h3><i class="fas fa-plus"></i> Tạo lô đất</h3></div>
<form method="POST" action="/housing/lots">
<div class="form-group"><label>Loại nhà</label><select name="type_code"><% types.forEach(t=>{ %><option value="<%= t.type_code %>"><%= t.name_vn %></option><% }) %></select></div>
<div class="form-group"><label>Địa chỉ</label><input name="address" placeholder="Số 12 Đường Hoa Anh Đào" required></div>
<div class="form-row"><div class="form-group"><label>Zone</label><input name="zone_id" type="number" value="1"></div>
<div class="form-group"><label>X</label><input name="pos_x" type="number" value="100"></div>
<div class="form-group"><label>Y</label><input name="pos_y" type="number" value="100"></div></div>
<button type="submit" class="btn btn-primary">Tạo lô</button></form></div>
<div class="card"><div class="card-header"><h3>Lô đất (<%= houses.length %>)</h3></div>
<table style="width:100%;border-collapse:collapse;font-size:.86rem">
<thead><tr style="text-align:left;color:var(--muted)"><th style="padding:6px">Địa chỉ</th><th>Loại</th><th>Zone</th><th>Chủ</th></tr></thead>
<tbody><% houses.forEach(h=>{ %><tr style="border-bottom:1px solid var(--border)">
<td style="padding:6px"><%= h.address %></td><td><%= h.type_name %></td><td><%= h.zone_id %></td><td><%= h.owner_char_id||'Đang bán' %></td></tr><% }) %></tbody></table></div>
