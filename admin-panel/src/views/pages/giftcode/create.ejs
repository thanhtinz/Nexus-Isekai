
<div class="card" style="max-width:600px">
  <div class="card-header">
    <h3><i class="fas fa-gift"></i> Tạo Giftcode mới</h3>
    <a href="/giftcode" class="btn btn-ghost btn-sm"><i class="fas fa-arrow-left"></i> Quay lại</a>
  </div>
  <form method="POST" action="/giftcode/create">
    <div class="form-row">
      <div class="form-group">
        <label>Prefix (tùy chọn)</label>
        <input name="prefix" placeholder="VD: KHAIMO → KHAIMO-AB1234">
      </div>
      <div class="form-group">
        <label>Số lượng tạo</label>
        <input name="count" type="number" value="1" min="1" max="500">
      </div>
    </div>
    <div class="form-row">
      <div class="form-group">
        <label>Giới hạn dùng / mã</label>
        <input name="max_uses" type="number" value="1" min="1">
      </div>
      <div class="form-group">
        <label>Server áp dụng</label>
        <select name="server_id">
          <option value="">Tất cả server</option>
          <% servers.forEach(sv=>{ %><option value="<%= sv.id %>"><%= sv.name %></option><% }) %>
        </select>
      </div>
    </div>
    <div class="form-group">
      <label>Mô tả</label>
      <input name="description" placeholder="VD: Sự kiện khai trương SV1">
    </div>
    <div class="form-row">
      <div class="form-group">
        <label>Thưởng Gold</label>
        <input name="rewards_gold" type="number" placeholder="VD: 10000">
      </div>
      <div class="form-group">
        <label>Thưởng Items <small style="color:var(--muted)">(id:qty, id:qty)</small></label>
        <input name="rewards_items" placeholder="VD: 9001:1,1001:5">
      </div>
    </div>
    <div class="form-group">
      <label>Ngày hết hạn</label>
      <input name="expires_at" type="datetime-local">
    </div>
    <button type="submit" class="btn btn-primary"><i class="fas fa-save"></i> Tạo Giftcode</button>
  </form>
</div>
