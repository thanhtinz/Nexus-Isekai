# Nexus Isekai — Production Environment
# COPY to .env and fill real values. NEVER commit .env to git.

# Database
DB_URL=jdbc:mysql://localhost:3306/nexus_isekai?useSSL=true&serverTimezone=UTC
DB_USER=nexus
DB_PASS=CHANGE_ME_STRONG_PASSWORD

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASS=CHANGE_ME

# Server ports
GAME_PORT=7777
ADMIN_PORT=8080
WEB_PORT=9090

# Payment (SePay)
SEPAY_API_KEY=your_sepay_api_key
SEPAY_WEBHOOK_SECRET=your_webhook_secret
SEPAY_BANK_ACCOUNT=your_bank_account

# Social login (production verify)
GOOGLE_CLIENT_ID=your_google_client_id
FACEBOOK_APP_ID=your_fb_app_id
FACEBOOK_APP_SECRET=your_fb_secret
APPLE_TEAM_ID=your_apple_team_id

# Security
ADMIN_JWT_SECRET=CHANGE_ME_RANDOM_64_CHARS
PACKET_AES_KEY=CHANGE_ME_16_BYTES

# Claude API (AI content)
ANTHROPIC_API_KEY=your_anthropic_key
