<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D0D24">

    <!-- Game surface (full screen) -->
    <com.nexusisekai.ui.view.GameSurfaceView
        android:id="@+id/gameSurface"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>

    <!-- HUD overlay (top-left) -->
    <LinearLayout
        android:id="@+id/hudPanel"
        android:layout_width="220dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#99000022"
        android:padding="8dp"
        android:layout_gravity="top|start"
        android:layout_margin="8dp">

        <TextView
            android:id="@+id/tvPlayerName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Nhân vật"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:textStyle="bold"/>

        <ProgressBar
            android:id="@+id/pbHp"
            style="@android:style/Widget.ProgressBar.Horizontal"
            android:layout_width="match_parent"
            android:layout_height="10dp"
            android:progressTint="#00CC44"
            android:backgroundTint="#333333"
            android:layout_marginTop="4dp"/>

        <ProgressBar
            android:id="@+id/pbMp"
            style="@android:style/Widget.ProgressBar.Horizontal"
            android:layout_width="match_parent"
            android:layout_height="10dp"
            android:progressTint="#4488FF"
            android:backgroundTint="#333333"
            android:layout_marginTop="2dp"/>

        <ProgressBar
            android:id="@+id/pbExp"
            style="@android:style/Widget.ProgressBar.Horizontal"
            android:layout_width="match_parent"
            android:layout_height="6dp"
            android:progressTint="#FFCC00"
            android:backgroundTint="#333333"
            android:layout_marginTop="2dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="4dp">

            <TextView
                android:id="@+id/tvGold"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="0 G"
                android:textColor="#FFDD44"
                android:textSize="11sp"/>

            <TextView
                android:id="@+id/tvDiamond"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="0 💎"
                android:textColor="#88AAFF"
                android:textSize="11sp"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Notification (top-center) -->
    <TextView
        android:id="@+id/tvNotification"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|center_horizontal"
        android:layout_marginTop="16dp"
        android:background="#CC6C3EF3"
        android:paddingHorizontal="20dp"
        android:paddingVertical="10dp"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:textStyle="bold"
        android:visibility="gone"/>

    <!-- Bottom panel: chat + action buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:orientation="horizontal"
        android:layout_gravity="bottom"
        android:gravity="bottom"
        android:padding="8dp">

        <!-- Chat (left side) -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:background="#99000022"
            android:padding="6dp"
            android:layout_marginEnd="8dp">

            <ListView
                android:id="@+id/lvChat"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:scrollbars="none"
                android:divider="@null"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="36dp"
                android:orientation="horizontal">

                <EditText
                    android:id="@+id/etChatInput"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:hint="Nhắn tin..."
                    android:textColorHint="#555566"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    android:background="#22FFFFFF"
                    android:paddingHorizontal="8dp"/>

                <Button
                    android:id="@+id/btnChatSend"
                    android:layout_width="60dp"
                    android:layout_height="match_parent"
                    android:text="Gửi"
                    android:textSize="12sp"
                    android:backgroundTint="#6C3EF3"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Action buttons (right side) -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="bottom">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <Button android:id="@+id/btnInventory" android:layout_width="60dp" android:layout_height="50dp"
                    android:text="🎒" android:textSize="22sp" android:backgroundTint="#1A2A4A" android:layout_marginEnd="4dp"/>
                <Button android:id="@+id/btnQuest" android:layout_width="60dp" android:layout_height="50dp"
                    android:text="📜" android:textSize="22sp" android:backgroundTint="#1A2A4A" android:layout_marginEnd="4dp"/>
                <Button android:id="@+id/btnSkill" android:layout_width="60dp" android:layout_height="50dp"
                    android:text="⚡" android:textSize="22sp" android:backgroundTint="#1A2A4A" android:layout_marginEnd="4dp"/>
                <Button android:id="@+id/btnPet" android:layout_width="60dp" android:layout_height="50dp"
                    android:text="🐉" android:textSize="22sp" android:backgroundTint="#1A2A4A"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button android:id="@+id/btnGiftCode" android:layout_width="60dp" android:layout_height="50dp"
                    android:text="🎁" android:textSize="22sp" android:backgroundTint="#2A1A4A" android:layout_marginEnd="4dp"/>
                <Button android:id="@+id/btnMap" android:layout_width="60dp" android:layout_height="50dp"
                    android:text="🗺️" android:textSize="20sp" android:backgroundTint="#1A2A4A" android:layout_marginEnd="4dp"/>
                <Button android:id="@+id/btnGuild" android:layout_width="60dp" android:layout_height="50dp"
                    android:text="🏰" android:textSize="22sp" android:backgroundTint="#1A2A4A" android:layout_marginEnd="4dp"/>
                <Button android:id="@+id/btnLeaderboard" android:layout_width="60dp" android:layout_height="50dp"
                    android:text="🏆" android:textSize="22sp" android:backgroundTint="#1A2A4A"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
