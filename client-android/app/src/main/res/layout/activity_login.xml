<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D0D24"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp"
        android:minHeight="500dp">

        <!-- Logo -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⚔️"
            android:textSize="56sp"
            android:gravity="center"
            android:layout_gravity="center"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="NEXUS ISEKAI"
            android:textColor="#FFFFFF"
            android:textSize="28sp"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:layout_gravity="center"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="MMORPG"
            android:textColor="#8A8AAA"
            android:textSize="13sp"
            android:layout_gravity="center"
            android:layout_marginBottom="40dp"/>

        <!-- Login fields -->
        <EditText
            android:id="@+id/etUsername"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:hint="Tên đăng nhập"
            android:textColor="#FFFFFF"
            android:textColorHint="#5A5A7A"
            android:background="@drawable/input_bg"
            android:padding="14dp"
            android:inputType="text"
            android:imeOptions="actionNext"
            android:layout_marginBottom="12dp"/>

        <EditText
            android:id="@+id/etPassword"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:hint="Mật khẩu"
            android:textColor="#FFFFFF"
            android:textColorHint="#5A5A7A"
            android:background="@drawable/input_bg"
            android:padding="14dp"
            android:inputType="textPassword"
            android:imeOptions="actionDone"
            android:layout_marginBottom="20dp"/>

        <!-- Register fields (hidden by default) -->
        <LinearLayout
            android:id="@+id/registerGroup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <EditText
                android:id="@+id/etRegUsername"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:hint="Tên đăng nhập (≥3 ký tự)"
                android:textColor="#FFFFFF"
                android:textColorHint="#5A5A7A"
                android:background="@drawable/input_bg"
                android:padding="14dp"
                android:inputType="text"
                android:layout_marginBottom="12dp"/>

            <EditText
                android:id="@+id/etRegPassword"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:hint="Mật khẩu (≥6 ký tự)"
                android:textColor="#FFFFFF"
                android:textColorHint="#5A5A7A"
                android:background="@drawable/input_bg"
                android:padding="14dp"
                android:inputType="textPassword"
                android:layout_marginBottom="12dp"/>

            <EditText
                android:id="@+id/etRegEmail"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:hint="Email (tuỳ chọn)"
                android:textColor="#FFFFFF"
                android:textColorHint="#5A5A7A"
                android:background="@drawable/input_bg"
                android:padding="14dp"
                android:inputType="textEmailAddress"
                android:layout_marginBottom="20dp"/>
        </LinearLayout>

        <!-- Status -->
        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Đang kết nối..."
            android:textColor="#8A8AAA"
            android:textSize="13sp"
            android:gravity="center"
            android:layout_marginBottom="20dp"/>

        <!-- Login button -->
        <Button
            android:id="@+id/btnLogin"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Đăng nhập"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            android:backgroundTint="#6C3EF3"
            android:layout_marginBottom="12dp"/>

        <!-- Register button (ghost) -->
        <Button
            android:id="@+id/btnRegister"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Đăng ký"
            android:textColor="#6C3EF3"
            android:textSize="16sp"
            android:backgroundTint="#1A1A35"
            android:strokeColor="#6C3EF3"
            android:strokeWidth="1dp"
            android:layout_marginBottom="12dp"
            android:visibility="gone"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <Button
                android:id="@+id/btnToRegister"
                style="?attr/borderlessButtonStyle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Đăng ký tài khoản"
                android:textColor="#8A8AAA"
                android:textSize="13sp"/>

            <Button
                android:id="@+id/btnToLogin"
                style="?attr/borderlessButtonStyle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Đã có tài khoản"
                android:textColor="#8A8AAA"
                android:textSize="13sp"
                android:visibility="gone"/>
        </LinearLayout>

    </LinearLayout>
</ScrollView>
